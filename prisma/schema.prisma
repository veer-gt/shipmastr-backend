model Merchant {
  id                  String                       @id @default(cuid())
  name                String
  email               String                       @unique
  phone               String?
  gstin               String?
  panEncrypted        String?
  panIv               String?
  panAuthTag          String?
  panMasked           String?
  onboardingStatus    MerchantOnboardingStatus     @default(PENDING)
  pickupAddressStatus MerchantOnboardingStepStatus @default(PENDING)
  kycStatus           MerchantOnboardingStepStatus @default(PENDING)
  bankStatus          MerchantOnboardingStepStatus @default(PENDING)
  firstShipmentStatus MerchantOnboardingStepStatus @default(PENDING)
  onboardingNotes     String?
  sellerKycStatus     SellerKycStatus              @default(NOT_STARTED)
  sellerKycChecklist  Json                         @default("{}")
  sellerKycNotes      String?
  sellerKycReviewedAt DateTime?
  sellerKycReviewedBy String?
  adminStatus         MerchantAdminStatus          @default(NEW)
  adminNotes          String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  users                      User[]
  leads                      Lead[]
  firstShipmentRequests      FirstShipmentRequest[]
  orders                     Order[]
  orderImportBatches         OrderImportBatch[]
  auditLogs                  AuditLog[]
  securityFixtureTenants     SecurityFixtureTenant[]     @relation("SecurityFixtureMerchant")
  gstinRecords               MerchantGstinRecord[]
  pickupPoints               MerchantPickupPoint[]
  warehouses                 MerchantWarehouse[]
  customers                  MerchantCustomer[]
  domains                    MerchantDomain[]
  storefronts                Storefront[]
  storefrontAssets           StorefrontAsset[]
  storefrontProducts         StorefrontProduct[]
  checkoutRulesVersions      CheckoutRulesVersion[]
  checkoutSettings           CheckoutMerchantSetting?
  checkoutQuotes             CheckoutQuote[]
  checkoutOrders             CheckoutOrder[]
  checkoutPayments           CheckoutPayment[]
  checkoutAccountingEvents   CheckoutAccountingEvent[]
  checkoutIdempotencyKeys    CheckoutIdempotencyKey[]
  checkoutAddressSessions    CheckoutAddressSession[]
  checkoutAuditLogs          CheckoutAuditLog[]
  domainProvisioningEvents   DomainProvisioningEvent[]
  h2bEndpoints               H2BConnectionEndpoint[]
  h2bAdmissions              H2BWebhookAdmission[]
  h2bOutboxes                H2BWebhookOutbox[]
  h2bExternalOrderAggregates H2BExternalOrderAggregate[]

  @@index([adminStatus])
  @@index([onboardingStatus])
  @@index([gstin])
  @@index([panMasked])
  @@index([sellerKycStatus])
}

model Storefront {
  id         String   @id @default(cuid())
  merchantId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  domains  StorefrontDomain[]
  settings StorefrontSettings?
  products StorefrontProduct[]

  @@index([merchantId])
}

model StorefrontDomain {
  id                         String       @id @default(cuid())
  storefrontId               String
  domain                     String       @unique
  status                     DomainStatus @default(REQUESTED)
  isPrimary                  Boolean      @default(false)
  verificationStatus         String?
  dnsTarget                  String?
  cloudflareCustomHostnameId String?
  sslStatus                  String?
  failureReason              String?
  lastCheckedAt              DateTime?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  storefront Storefront                @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  events     DomainProvisioningEvent[]

  @@index([storefrontId])
  @@index([status])
}

model StorefrontSettings {
  id           String   @id @default(cuid())
  storefrontId String   @unique
  themeJson    Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storefront Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
}

enum StorefrontAssetStatus {
  PENDING
  READY
  DELETED
}

// SF1: images live here (GCS-backed), never as bytes in themeJson. themeJson only ever
// stores a reference (imageAssetId) to a row here with status = READY.
model StorefrontAsset {
  id         String                @id @default(cuid())
  merchantId String
  gcsPath    String                @unique
  mime       String
  bytes      Int?
  width      Int?
  height     Int?
  sha256     String?
  status     StorefrontAssetStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  merchant Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products StorefrontProduct[]

  @@index([merchantId])
  @@index([status])
  @@index([sha256])
}

// SF5 Layer 3: the server-authoritative source of truth for storefront product pricing.
// Public checkout quotes must resolve priceMinor from here by (merchantId, id) —
// never accept a price from the storefront/client payload.
model StorefrontProduct {
  id           String   @id @default(cuid())
  storefrontId String
  merchantId   String
  name         String
  priceMinor   Int
  currency     String   @default("INR")
  description  String?
  imageAssetId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storefront Storefront       @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  merchant   Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  imageAsset StorefrontAsset? @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)

  @@index([storefrontId])
  @@index([merchantId])
  @@index([imageAssetId])
}

model DomainProduct {
  id                     String         @id @default(cuid())
  tld                    String
  provider               DomainProvider @default(RESELLERCLUB)
  registrationPricePaise Int
  renewalPricePaise      Int
  transferPricePaise     Int            @default(0)
  currency               String         @default("INR")
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([tld, provider])
  @@index([provider])
  @@index([isActive])
}

model MerchantDomain {
  id                         String               @id @default(cuid())
  merchantId                 String
  storefrontId               String?
  domain                     String
  normalizedDomain           String               @unique
  source                     MerchantDomainSource
  provider                   DomainProvider       @default(RESELLERCLUB)
  status                     DomainStatus         @default(SEARCHED)
  isPrimary                  Boolean              @default(false)
  resellerClubEntityId       String?
  resellerClubOrderId        String?
  cloudflareCustomHostnameId String?
  sslStatus                  String?
  validationRecords          Json?
  expiresAt                  DateTime?
  autoRenew                  Boolean              @default(true)
  lastCheckedAt              DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  merchant Merchant                  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  events   DomainProvisioningEvent[]

  @@index([merchantId])
  @@index([storefrontId])
  @@index([status])
  @@index([provider])
  @@index([resellerClubEntityId])
  @@index([cloudflareCustomHostnameId])
  @@index([expiresAt])
  @@index([createdAt])
}

model DomainProvisioningEvent {
  id                  String                   @id @default(cuid())
  merchantId          String?
