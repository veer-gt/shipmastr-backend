  id               String   @id @default(uuid())
  merchantId       String   @unique
  totalOrders      Int      @default(0)
  codOrders        Int      @default(0)
  prepaidOrders    Int      @default(0)
  deliveredOrders  Int      @default(0)
  ndrOrders        Int      @default(0)
  rtoOrders        Int      @default(0)
  fraudSignalCount Int      @default(0)
  codExposure      Decimal  @default(0) @db.Decimal(12, 2)
  orderValueTotal  Decimal  @default(0) @db.Decimal(12, 2)
  rtoRate          Decimal  @default(0) @db.Decimal(5, 4)
  ndrRate          Decimal  @default(0) @db.Decimal(5, 4)
  deliveryRate     Decimal  @default(0) @db.Decimal(5, 4)
  trustScore       Int      @default(50)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([merchantId])
  @@index([createdAt])
}

