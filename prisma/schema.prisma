  updatedAt     DateTime @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([active])
  @@index([secretRef])
}

model CourierDeveloperCredential {
  id             String   @id @default(cuid())
  courierId      String
  environment    String   @default("sandbox")
  credentialType String
  maskedValue    String
  secretRef      String   @unique
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@unique([courierId, environment, credentialType])
  @@index([courierId])
  @@index([environment])
  @@index([credentialType])
  @@index([status])
}

model CourierApiEvent {
  id                String   @id @default(cuid())
  courierId         String
  courierShipmentId String?
  eventType         String
  externalEventId   String?
  source            String   @default("INBOUND_COURIER")
  status            String   @default("ACCEPTED")
  signatureValid    Boolean  @default(false)
  error             String?
  rawPayload        Json?
  createdAt         DateTime @default(now())

  courier  CourierPartner   @relation(fields: [courierId], references: [id], onDelete: Cascade)
  shipment CourierShipment? @relation(fields: [courierShipmentId], references: [id], onDelete: SetNull)

  @@index([courierId])
  @@index([courierShipmentId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([externalEventId])
}

model CourierInvoice {
  id            String   @id @default(cuid())
  courierId     String
  invoiceNumber String?
  periodStart   DateTime
  periodEnd     DateTime
  shipmentCount Int      @default(0)
  payableAmount Int      @default(0)
  deductions    Int      @default(0)
  totalAmount   Decimal? @db.Decimal(12, 2)
  gstAmount     Decimal? @db.Decimal(12, 2)
  status        String   @default("draft")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courier CourierPartner       @relation(fields: [courierId], references: [id], onDelete: Cascade)
  lines   CourierInvoiceLine[]

  @@index([courierId])
  @@index([status])
  @@index([invoiceNumber])
}

model CourierInvoiceLine {
  id                 String   @id @default(uuid())
  courierInvoiceId   String
  merchantId         String?
  courierId          String
  awb                String?
  orderId            String?
  externalOrderId    String?
  chargedWeightGrams Int?
  billedWeightGrams  Int?
  zone               String?
  forwardFreight     Decimal  @default(0) @db.Decimal(12, 2)
  rtoFreight         Decimal  @default(0) @db.Decimal(12, 2)
  codFee             Decimal  @default(0) @db.Decimal(12, 2)
  otherCharges       Decimal  @default(0) @db.Decimal(12, 2)
  gstAmount          Decimal  @default(0) @db.Decimal(12, 2)
  totalCharge        Decimal  @db.Decimal(12, 2)
  rawPayload         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  invoice CourierInvoice @relation(fields: [courierInvoiceId], references: [id], onDelete: Cascade)

  @@index([courierInvoiceId])
  @@index([merchantId])
  @@index([courierId])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
}

model CourierImportFile {
  id                String              @id @default(uuid())
  merchantId        String
  courierId         String?
  fileName          String
  mimeType          String?
  fileHash          String
  status            CourierImportStatus @default(UPLOADED)
  totalRows         Int                 @default(0)
  validRows         Int                 @default(0)
  invalidRows       Int                 @default(0)
  duplicateAwbRows  Int                 @default(0)
  metadata          Json?
  importedInvoiceId String?
  importedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  rows CourierImportRow[]

  @@unique([merchantId, fileHash])
  @@index([merchantId])
  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model CourierImportRow {
  id              String   @id @default(uuid())
