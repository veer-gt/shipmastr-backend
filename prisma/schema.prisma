model SellerWalletLedger {
  id                 String    @id @default(uuid())
  merchantId         String
  orderId            String?
  awb                String?
  entryType          String
  direction          String
  amount             Decimal   @db.Decimal(12, 2)
  currency           String    @default("INR")
  status             String    @default("POSTED")
  balanceBefore      Decimal?  @db.Decimal(12, 2)
  balanceAfter       Decimal?  @db.Decimal(12, 2)
  referenceType      String?
  referenceId        String?
  idempotencyKey     String?
  description        String?
  metadata           Json?
  createdBy          String?
  postedAt           DateTime? @default(now())
  reversedByLedgerId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  @@unique([merchantId, idempotencyKey])
  @@index([merchantId])
  @@index([orderId])
  @@index([awb])
  @@index([entryType])
  @@index([status])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

enum WalletOwnerType {
  seller
  courier
  platform
  gateway

  @@map("owner_type")
}

enum WalletAccountClass {
  asset
  liability
  revenue
  expense

  @@map("account_class")
}

enum WalletAccountType {
  shipping_balance
  cod_receivable
  dispute_hold
  seller_shortfall
  checkout_balance
  courier_payable
  courier_cod_due
  courier_suspense
  platform_escrow
  gateway_clearing
  platform_revenue
  fee_expense
  tax_payable
  courier_leakage

  @@map("account_type")
}

enum WalletAccountStatus {
  active
  preview
  locked
  frozen
  closed

  @@map("account_status")
}

enum LedgerScope {
  custodial
  shadow

  @@map("ledger_scope")
}

enum WalletEntryType {
  topup
  topup_refund
  gateway_settlement
  shipment_charge
  shipment_refund
  rto_freight_charge
  return_freight_charge
  weight_dispute_hold
  weight_dispute_release
  weight_dispute_capture
  cod_collected
  cod_remittance_in
  cod_payout
  courier_net_settlement
  checkout_capture
  checkout_split_settlement
  success_fee
  platform_fee
  adjustment
  suspense_recovery
  suspense_writeoff
  closure_refund_to_source
  closure_bank_settlement

  @@map("entry_type")
}

enum PostingDirection {
  debit
  credit

  @@map("posting_direction")
}

enum WalletHoldStatus {
  active
  released
  captured
  expired

  @@map("hold_status")
}

model WalletOwner {
  id          String          @id @default(cuid())
  ownerType   WalletOwnerType @map("owner_type")
  externalId  String?         @map("external_id")
  displayName String?         @map("display_name")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

  accounts WalletAccount[]

  @@unique([ownerType, externalId])
  @@index([ownerType])
  @@map("wallet_owners")
}

model WalletAccount {
  id           String              @id @default(cuid())
  ownerId      String              @map("owner_id")
  ownerType    WalletOwnerType     @map("owner_type")
  accountType  WalletAccountType   @map("account_type")
  accountClass WalletAccountClass  @map("account_class")
  status       WalletAccountStatus @default(active)
  ledgerScope  LedgerScope         @map("ledger_scope")
  currency     String              @default("INR")
  label        String?
  metadata     Json?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at")

  owner    WalletOwner      @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  balance  AccountBalance?
  postings JournalPosting[]
  holds    WalletHold[]

  @@unique([ownerId, accountType, ledgerScope, currency])
  @@index([ownerId])
  @@index([ownerType])
  @@index([accountType])
  @@index([ledgerScope])
  @@index([status])
  @@map("wallet_accounts")
}

model AccountTypeConfig {
  accountType         WalletAccountType  @id @map("account_type")
  accountClass        WalletAccountClass @map("account_class")
  normalSide          PostingDirection   @map("normal_side")
  allowedOwnerTypes   WalletOwnerType[]  @map("allowed_owner_types")
  allowedLedgerScopes LedgerScope[]      @map("allowed_ledger_scopes")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at")

  @@map("account_type_config")
}

model JournalEntry {
  id          String          @id @default(cuid())
  entryRef    String          @map("entry_ref")
  commandHash String          @map("command_hash")
  entryType   WalletEntryType @map("entry_type")
  ledgerScope LedgerScope     @map("ledger_scope")
  currency    String          @default("INR")
  sourceType  String          @map("source_type")
  sourceRef   String          @map("source_ref")
  reversalOf  String?         @map("reversal_of")
  narrative   String?
  createdBy   String?         @map("created_by")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  postings        JournalPosting[]
  reversedEntry   JournalEntry?    @relation("JournalEntryReversal", fields: [reversalOf], references: [id], onDelete: Restrict)
  reversalEntries JournalEntry[]   @relation("JournalEntryReversal")

  @@unique([entryRef])
  @@index([entryType])
  @@index([ledgerScope])
  @@index([reversalOf])
  @@index([sourceType, sourceRef])
  @@index([createdAt])
  @@map("journal_entries")
}

model JournalPosting {
  id          String           @id @default(cuid())
  entryId     String           @map("entry_id")
  accountId   String           @map("account_id")
  direction   PostingDirection
  amountPaise BigInt           @map("amount_paise")
  currency    String           @default("INR")
  createdAt   DateTime         @default(now()) @map("created_at")

  entry   JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Restrict)
  account WalletAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
  @@index([currency])
  @@map("journal_postings")
}

model AccountBalance {
  accountId          String      @id @map("account_id")
  ledgerScope        LedgerScope @map("ledger_scope")
  currency           String      @default("INR")
  balancePaise       BigInt      @default(0) @map("balance_paise")
  lastJournalEntryId String?     @map("last_journal_entry_id")
  updatedAt          DateTime    @default(now()) @updatedAt @map("updated_at")

  account WalletAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([ledgerScope])
  @@index([currency])
  @@map("account_balances")
}

model WalletHold {
  id                String           @id @default(cuid())
  accountId         String           @map("account_id")
  entryId           String           @map("entry_id")
  holdRef           String           @map("hold_ref")
  amountPaise       BigInt           @map("amount_paise")
  currency          String           @default("INR")
  status            WalletHoldStatus @default(active)
  sourceType        String           @map("source_type")
  sourceRef         String           @map("source_ref")
  releasedByEntryId String?          @map("released_by_entry_id")
  expiresAt         DateTime?        @map("expires_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")

  account WalletAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([holdRef])
  @@index([accountId])
  @@index([entryId])
  @@index([status])
  @@index([sourceType, sourceRef])
  @@map("wallet_holds")
}

model WalletTopupIntent {
  id             String    @id @default(cuid())
  topupRef       String    @unique @map("topup_ref")
  sellerOrgId    String    @map("seller_org_id")
  amountPaise    BigInt    @map("amount_paise")
  currency       String    @default("INR")
  status         String    @default("created")
  sourceRefHash  String    @map("source_ref_hash")
  createdBy      String?   @map("created_by")
  confirmedBy    String?   @map("confirmed_by")
  journalEntryId String?   @map("journal_entry_id")
  metadata       Json?
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([sellerOrgId])
  @@index([status])
  @@index([sourceRefHash])
  @@map("wallet_topup_intents")
}

model SettlementBatch {
  id          String      @id @default(cuid())
  batchRef    String      @unique @map("batch_ref")
  ledgerScope LedgerScope @map("ledger_scope")
  currency    String      @default("INR")
  status      String      @default("draft")
  batchType   String      @map("batch_type")
  totalPaise  BigInt      @default(0) @map("total_paise")
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")

  items SettlementBatchItem[]

  @@index([ledgerScope])
  @@index([status])
  @@index([createdAt])
  @@map("settlement_batches")
}

model SettlementBatchItem {
  id             String   @id @default(cuid())
  batchId        String   @map("batch_id")
  ownerId        String?  @map("owner_id")
  accountId      String?  @map("account_id")
  amountPaise    BigInt   @map("amount_paise")
  currency       String   @default("INR")
  sourceType     String   @map("source_type")
  sourceRef      String   @map("source_ref")
  status         String   @default("pending")
  journalEntryId String?  @map("journal_entry_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  batch SettlementBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([ownerId])
  @@index([accountId])
  @@index([sourceType, sourceRef])
  @@index([status])
  @@map("settlement_batch_items")
}

model ExternalTransaction {
  id                String    @id @default(cuid())
  provider          String
  transactionType   String    @map("transaction_type")
  externalRef       String    @map("external_ref")
  occurredAt        DateTime? @map("occurred_at")
  amountPaise       BigInt    @map("amount_paise")
  currency          String    @default("INR")
  rawPayload        Json?     @map("raw_payload")
  normalizedPayload Json?     @map("normalized_payload")
  createdAt         DateTime  @default(now()) @map("created_at")

  matches ExternalTransactionMatch[]

  @@unique([provider, externalRef])
  @@index([transactionType])
  @@index([occurredAt])
  @@index([createdAt])
  @@map("external_transactions")
}

model ExternalTransactionMatch {
  id                    String   @id @default(cuid())
  externalTransactionId String   @map("external_transaction_id")
  journalEntryId        String?  @map("journal_entry_id")
  matchStatus           String   @default("pending") @map("match_status")
  confidence            String?
  metadata              Json?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  externalTransaction ExternalTransaction @relation(fields: [externalTransactionId], references: [id], onDelete: Restrict)

  @@index([externalTransactionId])
  @@index([journalEntryId])
  @@index([matchStatus])
  @@map("external_transaction_matches")
}

model ReconException {
  id         String      @id @default(cuid())
  scope      LedgerScope
  sourceType String      @map("source_type")
  sourceRef  String      @map("source_ref")
  severity   String      @default("medium")
  status     String      @default("open")
  reasonCode String      @map("reason_code")
  details    Json?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at")

  @@index([scope])
  @@index([sourceType, sourceRef])
  @@index([status])
  @@index([createdAt])
  @@map("recon_exceptions")
}

model WalletEventsOutbox {
  id            String    @id @default(cuid())
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       Json
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  publishedAt   DateTime? @map("published_at")

  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([status, createdAt])
  @@map("wallet_events_outbox")
}

model CodNettingBatch {
  id                       String   @id @default(cuid())
  sellerOrgId              String   @map("seller_org_id")
  courierCode              String   @map("courier_code")
  period                   String
  sourceRef                String   @map("source_ref")
  sourceHash               String   @map("source_hash")
  status                   String   @default("draft")
  currency                 String   @default("INR")
  codCollectedMinor        BigInt   @default(0) @map("cod_collected_minor")
  freightDeductionMinor    BigInt   @default(0) @map("freight_deduction_minor")
  rtoDeductionMinor        BigInt   @default(0) @map("rto_deduction_minor")
  adjustmentMinor          BigInt   @default(0) @map("adjustment_minor")
  sellerNetReceivableMinor BigInt   @default(0) @map("seller_net_receivable_minor")
  negativeNetMinor         BigInt   @default(0) @map("negative_net_minor")
  reviewRequiredCount      Int      @default(0) @map("review_required_count")
  metadata                 Json?
  createdBy                String?  @map("created_by")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at")

  items  CodNettingItem[]
  events CodNettingInstructionEvent[]

  @@unique([sellerOrgId, courierCode, period, sourceRef])
  @@index([sellerOrgId])
  @@index([courierCode])
  @@index([period])
  @@index([status])
  @@index([createdAt])
  @@map("cod_netting_batches")
}

model CodNettingItem {
  id                       String    @id @default(cuid())
  batchId                  String    @map("batch_id")
  sellerOrgId              String    @map("seller_org_id")
  courierCode              String    @map("courier_code")
  period                   String
  shipmentId               String?   @map("shipment_id")
  deliveredAt              DateTime? @map("delivered_at")
  codCollectedMinor        BigInt    @default(0) @map("cod_collected_minor")
  freightDeductionMinor    BigInt    @default(0) @map("freight_deduction_minor")
  rtoDeductionMinor        BigInt    @default(0) @map("rto_deduction_minor")
  adjustmentMinor          BigInt    @default(0) @map("adjustment_minor")
  expectedRemittanceMinor  BigInt?   @map("expected_remittance_minor")
  remittanceRef            String?   @map("remittance_ref")
  sellerNetReceivableMinor BigInt    @default(0) @map("seller_net_receivable_minor")
  instructionType          String    @map("instruction_type")
  status                   String    @default("draft")
  reviewReasons            Json?     @map("review_reasons")
  sourceRowHash            String    @map("source_row_hash")
  metadata                 Json?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at")

  batch  CodNettingBatch              @relation(fields: [batchId], references: [id], onDelete: Restrict)
  events CodNettingInstructionEvent[]

  @@index([batchId])
  @@index([sellerOrgId])
  @@index([courierCode])
  @@index([shipmentId])
  @@index([status])
  @@map("cod_netting_items")
}

model CodNettingInstructionEvent {
  id        String   @id @default(cuid())
  batchId   String   @map("batch_id")
  itemId    String?  @map("item_id")
  eventType String   @map("event_type")
  status    String
  message   String?
  metadata  Json?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  batch CodNettingBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  item  CodNettingItem? @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([itemId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
