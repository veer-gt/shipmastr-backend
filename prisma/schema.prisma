generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMode {
  PREPAID
  COD
}

enum OrderStatus {
  CREATED
  RISK_SCORED
  VERIFIED
  HELD
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  NDR
  RTO
  CANCELLED
}

enum LegacyRiskDecision {
  SHIP
  VERIFY
  HOLD
  BLOCK

  @@map("RiskDecision")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskDecisionType {
  ALLOW
  OTP_REQUIRED
  PREPAID_ONLY
  HOLD
  BLOCK
}

enum CodDecision {
  ALLOW_COD
  REQUIRE_OTP
  PREPAID_ONLY
  MANUAL_REVIEW
}

enum ConsigneeTier {
  GOLD
  SILVER
  BRONZE
  IRON
}

enum ShipmentDecision {
  SHIP
  VERIFY_BEFORE_SHIP
  HOLD
  DO_NOT_SHIP
}

enum ActualOutcome {
  PENDING
  DELIVERED
  NDR
  RTO
  CANCELLED
  RETURNED
  LOST
}

enum AutonomousActionType {
  SEND_COD_OTP
  SEND_ADDRESS_CORRECTION_LINK
  HIDE_COD
  SEND_PREPAID_LINK
  AUTO_SELECT_COURIER
  HOLD_SHIPMENT
  RELEASE_SHIPMENT
  REQUEST_NDR_REATTEMPT
  SEND_NDR_RECOVERY_MESSAGE
  ESCALATE_INTERNAL_REVIEW
  REQUEST_SELLER_APPROVAL
}

enum AutomationLevel {
  AUTO_EXECUTE
  AUTO_EXECUTE_NOTIFY
  REQUIRE_SELLER_APPROVAL
  REQUIRE_INTERNAL_REVIEW
}

enum AutonomousActionStatus {
  PENDING
  EXECUTED
  FAILED
  CANCELLED
  APPROVED
  REJECTED
  EXPIRED
}

enum CommunicationChannel {
  WHATSAPP
  SMS
  EMAIL
  CALL
}

enum BuyerCommunicationResponse {
  OTP_VERIFIED
  OTP_FAILED
  ADDRESS_CONFIRMED
  ADDRESS_CORRECTED
  PREPAID_CONVERTED
  BUYER_CONFIRMED_REATTEMPT
  BUYER_REFUSED
  NO_RESPONSE
  INVALID_RESPONSE
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  RESPONDED
  FAILED
  EXPIRED
}

enum ReconciliationStatus {
  AUTO_APPROVED
  PARTIAL_MATCH
  COD_SHORTFALL
  COD_DELAYED
  INVOICE_MISMATCH
  WEIGHT_DISPUTE
  ZONE_DISPUTE
  DUPLICATE_BILLING
  MISSING_REMITTANCE
  RTO_CHARGE_REVIEW
  FAKE_ATTEMPT_REVIEW
  MANUAL_REVIEW
  PAYMENT_HOLD
  SETTLED
}

enum ReconciliationDisputeType {
  INVOICE_MISMATCH
  COD_SHORTFALL
  COD_DELAY
  DUPLICATE_BILLING
  UNKNOWN_AWB
  WEIGHT_DISPUTE
  ZONE_DISPUTE
  RTO_CHARGE_ISSUE
  FAKE_ATTEMPT_NDR_ISSUE
}

enum DisputeWorkflowStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum PaymentHoldStatus {
  ACTIVE
  RELEASED
  CANCELLED
}

enum SellerSettlementStatus {
  PENDING
  BLOCKED
  APPROVED
  SETTLED
}

enum CourierSettlementFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum CourierPenaltyType {
  COD_REMITTANCE_DELAY
}

enum CourierPenaltyStatus {
  CALCULATED
  APPLIED
  WAIVED
}

enum FinanceApprovalType {
  SELLER_SETTLEMENT
  PAYMENT_HOLD_RELEASE
  COURIER_SETTLEMENT
}

enum FinanceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CourierImportStatus {
  UPLOADED
  PREVIEWED
  IMPORTED
  FAILED
  DUPLICATE
}

enum JournalPostStatus {
  DRAFT
  PUBLISHED
  HELD
  SENT
}

enum NewsletterSubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum TrustTier {
  NEW
  WATCHLIST
  TRUSTED
  PREFERRED
  RISKY
  SUSPENDED
}

enum UserRole {
  SELLER
  COURIER
  ADMIN
}

enum MerchantOnboardingStatus {
  PENDING
  IN_PROGRESS
  READY_TO_SHIP
}

enum MerchantOnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum PasswordResetPurpose {
  INVITE
  RESET
}

enum FirstShipmentRequestStatus {
  NEW
  REVIEWING
  APPROVED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CourierEventType {
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  NDR
  RTO
  LOST
  CANCELLED
}

enum NdrReason {
  CUSTOMER_NOT_REACHABLE
  ADDRESS_ISSUE
  CUSTOMER_REFUSED
  PAYMENT_ISSUE
  RESCHEDULE_REQUESTED
  OTHER
}

enum RtoReason {
  FAILED_DELIVERY
  CUSTOMER_REFUSED
  ADDRESS_INCOMPLETE
  CUSTOMER_UNREACHABLE
  COURIER_ISSUE
  OTHER
}

enum SlaBreachType {
  AWB_GENERATION_FAILED
  PICKUP_DELAYED
  WEBHOOK_DELAYED
  TRACKING_STALE
  NDR_ACTION_DELAYED
  COD_REMITTANCE_DELAYED
  LEDGER_MISMATCH
}

enum WebhookProvider {
  CARRIER
  CHANNEL
  PAYMENT
  INTERNAL
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

model Merchant {
  id                  String                       @id @default(cuid())
  name                String
  email               String                       @unique
  phone               String?
  onboardingStatus    MerchantOnboardingStatus     @default(PENDING)
  pickupAddressStatus MerchantOnboardingStepStatus @default(PENDING)
  kycStatus           MerchantOnboardingStepStatus @default(PENDING)
  bankStatus          MerchantOnboardingStepStatus @default(PENDING)
  firstShipmentStatus MerchantOnboardingStepStatus @default(PENDING)
  onboardingNotes     String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  users     User[]
  leads     Lead[]
  firstShipmentRequests FirstShipmentRequest[]
  orders    Order[]
  auditLogs AuditLog[]
}

model CourierPartner {
  id                  String   @id @default(cuid())
  name                String
  code                String   @unique
  active              Boolean  @default(true)
  apiMode             String   @default("manual")
  supportsCOD         Boolean  @default(true)
  supportsPrepaid     Boolean  @default(true)
  supportsPickup      Boolean  @default(true)
  priority            Int      @default(100)
  trackingUrlTemplate String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rateCards      RateCard[]
  users          CourierUser[]
  shipments      CourierShipment[]
  webhookConfigs CourierWebhookConfig[]
  invoices       CourierInvoice[]
  financePolicies CourierFinancePolicy[]
  penalties       CourierPenalty[]

  @@index([active])
  @@index([priority])
}

model RateCard {
  id             String   @id @default(cuid())
  courierId      String
  zone           String
  minWeight      Int
  maxWeight      Int
  baseRate       Int
  additionalRate Int      @default(0)
  codFee         Int      @default(0)
  fuelSurcharge  Int      @default(0)
  rtoCharge      Int      @default(0)
  gstPercent     Decimal  @default(18.00) @db.Decimal(5, 2)
  etaDays        Int      @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([zone])
  @@index([minWeight, maxWeight])
}

model CourierUser {
  id           String    @id @default(cuid())
  courierId    String
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("courier_partner")
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([active])
}

model CourierShipment {
  id                   String      @id @default(cuid())
  courierId            String
  orderId              String?
  awbNumber            String      @unique
  fromPincode          String
  toPincode            String
  status               String      @default("pickup_scheduled")
  weightGrams          Int?
  paymentMode          PaymentMode @default(PREPAID)
  codAmount            Int         @default(0)
  lastEvent            String?
  expectedDeliveryDate DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)
  events  CourierEvent[]
  ndr     CourierNdr?
  rto     CourierRto?

  @@index([courierId])
  @@index([courierId, status])
  @@index([orderId])
}

model CourierEvent {
  id                String   @id @default(cuid())
  courierShipmentId String
  courierId         String
  courierUserId     String?
  eventType         String
  status            String
  location          String?
  remarks           String?
  rawPayload        Json?
  createdAt         DateTime @default(now())

  shipment CourierShipment @relation(fields: [courierShipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([courierShipmentId])
  @@index([status])
}

model CourierNdr {
  id                String    @id @default(cuid())
  courierShipmentId String    @unique
  courierId         String
  reason            String
  actionRequired    String
  nextAttemptDate   DateTime?
  remarks           String?
  status            String    @default("open")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  shipment CourierShipment @relation(fields: [courierShipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([status])
}

model CourierRto {
  id                 String    @id @default(cuid())
  courierShipmentId  String    @unique
  courierId          String
  rtoStatus          String
  reason             String
  expectedReturnDate DateTime?
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  shipment CourierShipment @relation(fields: [courierShipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([rtoStatus])
}

model CourierWebhookConfig {
  id        String   @id @default(cuid())
  courierId String
  targetUrl String
  secret    String
  active    Boolean  @default(true)
  events    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([active])
}

model CourierInvoice {
  id            String   @id @default(cuid())
  courierId     String
  invoiceNumber String?
  periodStart   DateTime
  periodEnd     DateTime
  shipmentCount Int      @default(0)
  payableAmount Int      @default(0)
  deductions    Int      @default(0)
  totalAmount   Decimal? @db.Decimal(12, 2)
  gstAmount     Decimal? @db.Decimal(12, 2)
  status        String   @default("draft")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)
  lines   CourierInvoiceLine[]

  @@index([courierId])
  @@index([status])
  @@index([invoiceNumber])
}

model CourierInvoiceLine {
  id                   String   @id @default(uuid())
  courierInvoiceId     String
  merchantId           String?
  courierId            String
  awb                  String?
  orderId              String?
  externalOrderId      String?
  chargedWeightGrams   Int?
  billedWeightGrams    Int?
  zone                 String?
  forwardFreight       Decimal  @default(0) @db.Decimal(12, 2)
  rtoFreight           Decimal  @default(0) @db.Decimal(12, 2)
  codFee               Decimal  @default(0) @db.Decimal(12, 2)
  otherCharges         Decimal  @default(0) @db.Decimal(12, 2)
  gstAmount            Decimal  @default(0) @db.Decimal(12, 2)
  totalCharge          Decimal  @db.Decimal(12, 2)
  rawPayload           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  invoice CourierInvoice @relation(fields: [courierInvoiceId], references: [id], onDelete: Cascade)

  @@index([courierInvoiceId])
  @@index([merchantId])
  @@index([courierId])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
}

model CourierImportFile {
  id                String              @id @default(uuid())
  merchantId        String
  courierId         String?
  fileName          String
  mimeType          String?
  fileHash          String
  status            CourierImportStatus @default(UPLOADED)
  totalRows         Int                 @default(0)
  validRows         Int                 @default(0)
  invalidRows       Int                 @default(0)
  duplicateAwbRows  Int                 @default(0)
  metadata          Json?
  importedInvoiceId String?
  importedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  rows CourierImportRow[]

  @@unique([merchantId, fileHash])
  @@index([merchantId])
  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model CourierImportRow {
  id             String   @id @default(uuid())
  importFileId   String
  rowNumber      Int
  awb            String?
  orderId        String?
  externalOrderId String?
  valid          Boolean  @default(false)
  duplicateAwb   Boolean  @default(false)
  errors         String[] @default([])
  rawData        Json
  normalizedData Json?
  createdAt      DateTime @default(now())

  importFile CourierImportFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([importFileId])
  @@index([rowNumber])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([valid])
}

model CodRemittance {
  id              String   @id @default(uuid())
  merchantId      String
  courierId       String?
  awb             String?
  orderId         String?
  externalOrderId String?
  codAmount       Decimal  @default(0) @db.Decimal(12, 2)
  remittedAmount  Decimal  @db.Decimal(12, 2)
  remittedAt      DateTime?
  utr             String?
  status          String   @default("imported")
  rawPayload      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([merchantId])
  @@index([courierId])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([remittedAt])
}

model CodRemittanceImportFile {
  id                 String              @id @default(uuid())
  merchantId         String
  fileName           String
  mimeType           String?
  fileHash           String
  status             CourierImportStatus @default(UPLOADED)
  totalRows          Int                 @default(0)
  validRows          Int                 @default(0)
  invalidRows        Int                 @default(0)
  duplicateAwbRows   Int                 @default(0)
  metadata           Json?
  importedRowCount   Int?
  importedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  rows CodRemittanceImportRow[]

  @@unique([merchantId, fileHash])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

model CodRemittanceImportRow {
  id              String   @id @default(uuid())
  importFileId    String
  rowNumber       Int
  awb             String?
  orderId         String?
  externalOrderId String?
  valid           Boolean  @default(false)
  duplicateAwb    Boolean  @default(false)
  errors          String[] @default([])
  rawData         Json
  normalizedData  Json?
  createdAt       DateTime @default(now())

  importFile CodRemittanceImportFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([importFileId])
  @@index([rowNumber])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([valid])
}

model SellerWalletLedger {
  id           String   @id @default(uuid())
  merchantId   String
  orderId      String?
  awb          String?
  entryType    String
  direction    String
  amount       Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal? @db.Decimal(12, 2)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([merchantId])
  @@index([orderId])
  @@index([awb])
  @@index([entryType])
  @@index([createdAt])
}

model SellerSettlement {
  id                     String                 @id @default(uuid())
  merchantId             String
  orderId                String?
  awb                    String?
  reconciliationResultId String?
  status                 SellerSettlementStatus @default(PENDING)
  codCollected           Decimal                @default(0) @db.Decimal(12, 2)
  courierCharge          Decimal                @default(0) @db.Decimal(12, 2)
  platformFee            Decimal                @default(0) @db.Decimal(12, 2)
  adjustmentAmount       Decimal                @default(0) @db.Decimal(12, 2)
  sellerPayable          Decimal                @db.Decimal(12, 2)
  approvedAt             DateTime?
  settledAt              DateTime?
  metadata               Json?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  reconciliationResult ReconciliationResult? @relation(fields: [reconciliationResultId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([orderId])
  @@index([awb])
  @@index([reconciliationResultId])
  @@index([status])
}

model ReconciliationRun {
  id               String   @id @default(uuid())
  merchantId       String?
  status           String   @default("COMPLETED")
  periodStart      DateTime?
  periodEnd        DateTime?
  totalResults     Int      @default(0)
  autoApprovedCount Int     @default(0)
  disputeCount     Int      @default(0)
  paymentHoldCount Int      @default(0)
  metadata         Json?
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  results ReconciliationResult[]

  @@index([merchantId])
  @@index([status])
  @@index([startedAt])
}

model ReconciliationResult {
  id                    String               @id @default(uuid())
  runId                 String
  merchantId             String
  orderId               String?
  externalOrderId       String?
  awb                   String?
  courierId             String?
  status                ReconciliationStatus
  expectedCourierCharge Decimal              @default(0) @db.Decimal(12, 2)
  invoicedCourierCharge Decimal?             @db.Decimal(12, 2)
  expectedCodAmount     Decimal              @default(0) @db.Decimal(12, 2)
  remittedCodAmount     Decimal?             @db.Decimal(12, 2)
  sellerPayable         Decimal?             @db.Decimal(12, 2)
  courierPayable        Decimal?             @db.Decimal(12, 2)
  mismatchAmount        Decimal              @default(0) @db.Decimal(12, 2)
  disputeAmount         Decimal              @default(0) @db.Decimal(12, 2)
  paymentHoldAmount     Decimal              @default(0) @db.Decimal(12, 2)
  reasons               String[]             @default([])
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  run         ReconciliationRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  disputes    ReconciliationDispute[]
  paymentHolds PaymentHold[]
  settlements SellerSettlement[]
  penalties   CourierPenalty[]

  @@index([runId])
  @@index([merchantId])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([awb])
  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model ReconciliationDispute {
  id                     String                    @id @default(uuid())
  reconciliationResultId String?
  merchantId             String?
  courierId              String?
  awb                    String?
  orderId                String?
  type                   ReconciliationDisputeType
  status                 DisputeWorkflowStatus     @default(OPEN)
  amount                 Decimal                   @default(0) @db.Decimal(12, 2)
  reason                 String
  evidence               Json?
  resolution             Json?
  resolvedAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  reconciliationResult ReconciliationResult? @relation(fields: [reconciliationResultId], references: [id], onDelete: SetNull)

  @@index([reconciliationResultId])
  @@index([merchantId])
  @@index([courierId])
  @@index([awb])
  @@index([orderId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model PaymentHold {
  id                     String            @id @default(uuid())
  reconciliationResultId String?
  merchantId             String
  orderId                String?
  awb                    String?
  reason                 String
  status                 PaymentHoldStatus @default(ACTIVE)
  amount                 Decimal           @db.Decimal(12, 2)
  releasedAt             DateTime?
  metadata               Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  reconciliationResult ReconciliationResult? @relation(fields: [reconciliationResultId], references: [id], onDelete: SetNull)

  @@index([reconciliationResultId])
  @@index([merchantId])
  @@index([orderId])
  @@index([awb])
  @@index([status])
  @@index([createdAt])
}

model CourierFinancePolicy {
  id                           String                     @id @default(uuid())
  merchantId                   String
  courierId                    String
  creditPeriodDays             Int                        @default(7)
  codRemittanceSlaDays         Int                        @default(7)
  penaltyGraceDays             Int                        @default(0)
  codDelayPenaltyRateBps       Int                        @default(50)
  codDelayPenaltyFixedAmount   Decimal                    @default(0) @db.Decimal(12, 2)
  maxCodDelayPenaltyAmount     Decimal?                   @db.Decimal(12, 2)
  settlementFrequency          CourierSettlementFrequency @default(WEEKLY)
  settlementAnchorDay          Int                        @default(5)
  makerCheckerRequired         Boolean                    @default(true)
  active                       Boolean                    @default(true)
  notes                        String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  courier CourierPartner @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@unique([merchantId, courierId])
  @@index([merchantId])
  @@index([courierId])
  @@index([active])
}

model CourierPenalty {
  id                     String               @id @default(uuid())
  merchantId             String
  courierId              String
  reconciliationResultId String?
  awb                    String?
  orderId                String?
  penaltyType            CourierPenaltyType
  status                 CourierPenaltyStatus @default(CALCULATED)
  baseAmount             Decimal              @default(0) @db.Decimal(12, 2)
  penaltyAmount          Decimal              @default(0) @db.Decimal(12, 2)
  delayedDays            Int                  @default(0)
  reason                 String
  calculatedAt           DateTime             @default(now())
  appliedAt              DateTime?
  waivedAt               DateTime?
  metadata               Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  courier              CourierPartner        @relation(fields: [courierId], references: [id], onDelete: Cascade)
  reconciliationResult ReconciliationResult? @relation(fields: [reconciliationResultId], references: [id], onDelete: SetNull)

  @@unique([reconciliationResultId, penaltyType])
  @@index([merchantId])
  @@index([courierId])
  @@index([penaltyType])
  @@index([status])
  @@index([calculatedAt])
}

model FinanceApprovalRequest {
  id              String                @id @default(uuid())
  merchantId      String
  approvalType    FinanceApprovalType
  status          FinanceApprovalStatus @default(PENDING)
  settlementId    String?
  paymentHoldId   String?
  courierId       String?
  amount          Decimal               @default(0) @db.Decimal(12, 2)
  reason          String
  requestedBy     String
  requestedAt     DateTime              @default(now())
  checkedBy       String?
  checkedAt       DateTime?
  rejectionReason String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([merchantId])
  @@index([approvalType])
  @@index([status])
  @@index([settlementId])
  @@index([paymentHoldId])
  @@index([courierId])
  @@index([requestedAt])
}

model PaymentBlockNote {
