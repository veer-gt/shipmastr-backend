  orderId    String?
  phoneHash  String
  decision   CodDecision
  riskLevel  RiskLevel
  success    Boolean     @default(false)
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([merchantId])
  @@index([orderId])
  @@index([phoneHash])
  @@index([createdAt])
}

