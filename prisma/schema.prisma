  createdAt       DateTime @default(now())

  importFile CourierImportFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([importFileId])
  @@index([rowNumber])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([valid])
}

model CodRemittance {
  id              String    @id @default(uuid())
  merchantId      String
  courierId       String?
  awb             String?
  orderId         String?
  externalOrderId String?
  codAmount       Decimal   @default(0) @db.Decimal(12, 2)
  remittedAmount  Decimal   @db.Decimal(12, 2)
  remittedAt      DateTime?
