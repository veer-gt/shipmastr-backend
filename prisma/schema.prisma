  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  shipment CourierShipment @relation(fields: [courierShipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([status])
}

model CourierRto {
  id                 String    @id @default(cuid())
  courierShipmentId  String    @unique
  courierId          String
  rtoStatus          String
  reason             String
  expectedReturnDate DateTime?
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  shipment CourierShipment @relation(fields: [courierShipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([rtoStatus])
}

model CourierWebhookConfig {
  id            String   @id @default(cuid())
  courierId     String
  targetUrl     String
  secret        String
  secretRef     String?
  maskedSecret  String?
