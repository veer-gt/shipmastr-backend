  updatedAt       DateTime  @updatedAt

  @@index([merchantId])
  @@index([courierId])
  @@index([awb])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([remittedAt])
}

model CodRemittanceImportFile {
  id               String              @id @default(uuid())
  merchantId       String
  fileName         String
  mimeType         String?
  fileHash         String
  status           CourierImportStatus @default(UPLOADED)
  totalRows        Int                 @default(0)
  validRows        Int                 @default(0)
  invalidRows      Int                 @default(0)
