model Merchant {
  id                  String                       @id @default(cuid())
  name                String
  email               String                       @unique
  phone               String?
  gstin               String?
  panEncrypted        String?
  panIv               String?
  panAuthTag          String?
  panMasked           String?
  onboardingStatus    MerchantOnboardingStatus     @default(PENDING)
  pickupAddressStatus MerchantOnboardingStepStatus @default(PENDING)
  kycStatus           MerchantOnboardingStepStatus @default(PENDING)
  bankStatus          MerchantOnboardingStepStatus @default(PENDING)
  firstShipmentStatus MerchantOnboardingStepStatus @default(PENDING)
  onboardingNotes     String?
  sellerKycStatus     SellerKycStatus              @default(NOT_STARTED)
  sellerKycChecklist  Json                         @default("{}")
  sellerKycNotes      String?
  sellerKycReviewedAt DateTime?
  sellerKycReviewedBy String?
  adminStatus         MerchantAdminStatus          @default(NEW)
  adminNotes          String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  users     User[]
  leads     Lead[]
  firstShipmentRequests FirstShipmentRequest[]
  orders    Order[]
  orderImportBatches OrderImportBatch[]
  auditLogs AuditLog[]
  gstinRecords MerchantGstinRecord[]
  pickupPoints MerchantPickupPoint[]
  domains MerchantDomain[]
  storefronts Storefront[]
  domainProvisioningEvents DomainProvisioningEvent[]

  @@index([adminStatus])
  @@index([onboardingStatus])
  @@index([gstin])
  @@index([panMasked])
  @@index([sellerKycStatus])
}

model Storefront {
  id         String   @id @default(cuid())
  merchantId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  domains  StorefrontDomain[]
  settings StorefrontSettings?

  @@index([merchantId])
}

model StorefrontDomain {
  id                         String       @id @default(cuid())
  storefrontId               String
  domain                     String       @unique
  status                     DomainStatus @default(REQUESTED)
  isPrimary                  Boolean      @default(false)
  verificationStatus         String?
  dnsTarget                  String?
  cloudflareCustomHostnameId String?
  sslStatus                  String?
  failureReason              String?
  lastCheckedAt              DateTime?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  storefront Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  events     DomainProvisioningEvent[]

  @@index([storefrontId])
  @@index([status])
}

model StorefrontSettings {
  id          String   @id @default(cuid())
  storefrontId String   @unique
  themeJson    Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storefront Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
}

model DomainProduct {
  id                      String         @id @default(cuid())
  tld                     String
  provider                DomainProvider @default(RESELLERCLUB)
  registrationPricePaise  Int
  renewalPricePaise       Int
  transferPricePaise      Int            @default(0)
  currency                String         @default("INR")
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@unique([tld, provider])
  @@index([provider])
  @@index([isActive])
}

model MerchantDomain {
  id                         String               @id @default(cuid())
  merchantId                 String
  storefrontId               String?
  domain                     String
  normalizedDomain           String               @unique
  source                     MerchantDomainSource
  provider                   DomainProvider       @default(RESELLERCLUB)
  status                     DomainStatus         @default(SEARCHED)
  isPrimary                  Boolean              @default(false)
  resellerClubEntityId       String?
  resellerClubOrderId        String?
  cloudflareCustomHostnameId String?
  sslStatus                  String?
  validationRecords          Json?
  expiresAt                  DateTime?
  autoRenew                  Boolean              @default(true)
  lastCheckedAt              DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  events   DomainProvisioningEvent[]

  @@index([merchantId])
  @@index([storefrontId])
  @@index([status])
  @@index([provider])
  @@index([resellerClubEntityId])
  @@index([cloudflareCustomHostnameId])
  @@index([expiresAt])
  @@index([createdAt])
}

model DomainProvisioningEvent {
  id                String                    @id @default(cuid())
  merchantId        String?
  merchantDomainId  String?
  storefrontDomainId String?
  storefrontId      String?
  provider          DomainProvider
  eventType         String
  status            DomainProvisioningStatus
  payload           Json?
  requestPayload    Json?
  responsePayload   Json?
  safeMessage       String?
  internalError     String?
  providerReferenceId String?
  idempotencyKey    String?
  createdAt         DateTime                  @default(now())

  merchant       Merchant?       @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  merchantDomain MerchantDomain? @relation(fields: [merchantDomainId], references: [id], onDelete: SetNull)
  storefrontDomain StorefrontDomain? @relation(fields: [storefrontDomainId], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey])
  @@index([merchantId])
  @@index([merchantDomainId])
  @@index([storefrontDomainId])
  @@index([storefrontId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([providerReferenceId])
  @@index([createdAt])
}

model CourierPartner {
  id                  String   @id @default(cuid())
  name                String
  code                String   @unique
  status              CourierPartnerStatus @default(active)
  isSystemManaged     Boolean  @default(false)
  defaultForNewSellers Boolean @default(false)
  credentialsRequiredFromSeller Boolean @default(true)
  country             String   @default("IN")
  supportedSegments   ShipmentSegment[] @default([])
  gstin               String?
  serviceCodeType     String   @default("SAC")
  serviceCode         String   @default("996812")
  serviceDescription  String   @default("Courier services")
  gstRate             Int      @default(18)
  active              Boolean  @default(true)
  apiMode             String   @default("manual")
  bookingMode         String   @default("manual")
  supportsCOD         Boolean  @default(true)
  supportsPrepaid     Boolean  @default(true)
  supportsPickup      Boolean  @default(true)
  priority            Int      @default(100)
  trackingUrlTemplate String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rateCards      RateCard[]
  users          CourierUser[]
  shipments      CourierShipment[]
  webhookConfigs CourierWebhookConfig[]
  invoices       CourierInvoice[]
  financePolicies CourierFinancePolicy[]
  penalties       CourierPenalty[]
  onboarding      CourierPartnerOnboarding?
  onboardingSecrets CourierPartnerSecret[]
  sandboxVerificationChecklist CourierSandboxVerificationChecklistItem[]
  gstinRecords CourierGstinRecord[]
  operationalLocations CourierOperationalLocation[]
  serviceablePincodes CourierServiceablePincode[]
  pilotChecklist CourierPilotChecklistItem[]
  developerCredentials CourierDeveloperCredential[]
  apiEvents CourierApiEvent[]
  sellerCourierPartners SellerCourierPartner[]
  pickupLocationProviderMappings PickupLocationProviderMapping[]
  networkShipments Shipment[]
  shipmentProviderRefs ShipmentProviderRef[]
  shipmentRates ShipmentRate[]
  shipmentTrackingEvents ShipmentTrackingEvent[]

  @@index([status])
  @@index([active])
  @@index([priority])
  @@index([gstin])
  @@index([serviceCode])
  @@index([bookingMode])
  @@index([isSystemManaged])
  @@index([defaultForNewSellers])
  @@index([country])
}

model SellerCourierPartner {
  id                            String                     @id @default(cuid())
  sellerId                      String                     @map("seller_id")
  courierPartnerId              String                     @map("courier_partner_id")
  status                        SellerCourierPartnerStatus @default(active)
  partnerType                   PartnerType                @default(system_managed) @map("partner_type")
  credentialsRequiredFromSeller Boolean                    @default(false) @map("credentials_required_from_seller")
  enabledSegments               ShipmentSegment[]          @default([]) @map("enabled_segments")
  country                       String                     @default("IN")
  displayCode                   String                     @default("shipmastr_courier_network") @map("display_code")
  displayName                   String                     @default("Shipmastr Courier Network") @map("display_name")
  createdAt                     DateTime                   @default(now()) @map("created_at")
  updatedAt                     DateTime                   @default(now()) @updatedAt @map("updated_at")

  courierPartner CourierPartner @relation(fields: [courierPartnerId], references: [id], onDelete: Cascade)
  pickupLocationProviderMappings PickupLocationProviderMapping[]
  shipments Shipment[]
  shipmentRates ShipmentRate[]

  @@unique([sellerId, courierPartnerId])
  @@index([sellerId])
  @@index([courierPartnerId])
  @@index([status])
  @@index([partnerType])
  @@index([country])
  @@map("seller_courier_partners")
}

model PickupLocation {
  id           String   @id @default(cuid())
  sellerId     String   @map("seller_id")
  label        String
  contactName  String?  @map("contact_name")
  phone        String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  state        String?
  pincode      String?
  country      String   @default("IN")
  status       String   @default("active")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  providerMappings PickupLocationProviderMapping[]
  shipments Shipment[]
  orders Order[]

  @@index([sellerId])
  @@index([sellerId, status])
  @@index([pincode])
  @@index([country])
  @@map("pickup_locations")
}

model PickupLocationProviderMapping {
  id                     String   @id @default(cuid())
  pickupLocationId       String   @map("pickup_location_id")
  sellerCourierPartnerId String?  @map("seller_courier_partner_id")
  courierPartnerId       String   @map("courier_partner_id")
  providerPickupId       String?  @map("provider_pickup_id")
  providerCode           String?  @map("provider_code")
  status                 String   @default("active")
  metadata               Json?
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")

  pickupLocation PickupLocation @relation(fields: [pickupLocationId], references: [id], onDelete: Cascade)
  sellerCourierPartner SellerCourierPartner? @relation(fields: [sellerCourierPartnerId], references: [id], onDelete: SetNull)
  courierPartner CourierPartner @relation(fields: [courierPartnerId], references: [id], onDelete: Cascade)

  @@unique([pickupLocationId, courierPartnerId])
  @@index([pickupLocationId])
  @@index([sellerCourierPartnerId])
  @@index([courierPartnerId])
  @@index([providerPickupId])
  @@index([status])
  @@map("pickup_location_provider_mappings")
}

model Shipment {
  id                     String              @id @default(cuid())
  sellerId               String              @map("seller_id")
  orderId                String?             @map("order_id")
  externalOrderId        String?             @map("external_order_id")
  pickupLocationId       String?             @map("pickup_location_id")
  sellerCourierPartnerId String?             @map("seller_courier_partner_id")
  courierPartnerId       String?             @map("courier_partner_id")
  segment                ShipmentSegment     @default(domestic_b2c)
  status                 ShipmentStatus      @default(draft)
  paymentMode            ShippingPaymentMode @default(prepaid) @map("payment_mode")
  codAmountPaise         Int                 @default(0) @map("cod_amount_paise")
  declaredValuePaise     Int?                @map("declared_value_paise")
  fromPincode            String?             @map("from_pincode")
  toPincode              String?             @map("to_pincode")
  deadWeightKg           Decimal?            @map("dead_weight_kg") @db.Decimal(10, 3)
  lengthCm               Decimal?            @map("length_cm") @db.Decimal(10, 2)
  breadthCm              Decimal?            @map("breadth_cm") @db.Decimal(10, 2)
  heightCm               Decimal?            @map("height_cm") @db.Decimal(10, 2)
  volumetricDivisor      Int                 @default(5000) @map("volumetric_divisor")
  volumetricWeightKg     Decimal?            @map("volumetric_weight_kg") @db.Decimal(10, 3)
  chargeableWeightKg     Decimal?            @map("chargeable_weight_kg") @db.Decimal(10, 3)
  serviceLevel           String?             @map("service_level")
  awbNumber              String?             @unique @map("awb_number")
  trackingUrl            String?             @map("tracking_url")
  trackingToken          String?             @unique @map("tracking_token")
  trackingPublicUrl      String?             @map("tracking_public_url")
  trackingStatus         String?             @map("tracking_status")
  trackingLastSyncedAt   DateTime?           @map("tracking_last_synced_at")
  metadata               Json?
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @default(now()) @updatedAt @map("updated_at")

  pickupLocation PickupLocation? @relation(fields: [pickupLocationId], references: [id], onDelete: SetNull)
  sellerCourierPartner SellerCourierPartner? @relation(fields: [sellerCourierPartnerId], references: [id], onDelete: SetNull)
  courierPartner CourierPartner? @relation(fields: [courierPartnerId], references: [id], onDelete: SetNull)
  providerRefs ShipmentProviderRef[]
  rates ShipmentRate[]
  trackingEvents ShipmentTrackingEvent[]

  @@index([sellerId])
  @@index([orderId])
  @@index([externalOrderId])
  @@index([pickupLocationId])
  @@index([sellerCourierPartnerId])
  @@index([courierPartnerId])
  @@index([status])
  @@index([segment])
  @@index([paymentMode])
  @@index([fromPincode, toPincode])
  @@index([trackingToken])
  @@index([createdAt])
  @@map("shipments")
}

model ShipmentProviderRef {
  id                 String   @id @default(cuid())
  shipmentId         String   @map("shipment_id")
  courierPartnerId   String?  @map("courier_partner_id")
  providerShipmentId String?  @map("provider_shipment_id")
  providerAwb        String?  @map("provider_awb")
  providerOrderId    String?  @map("provider_order_id")
  providerPickupId   String?  @map("provider_pickup_id")
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
