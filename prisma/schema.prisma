  eventType          GrowthBillingEventType @map("event_type")
  amountPaise        Int?                   @map("amount_paise")
  currency           String                 @default("INR")
  simulationSnapshot Json                   @map("simulation_snapshot")
  createdAt          DateTime               @default(now()) @map("created_at")

  @@index([merchantId])
  @@index([partnerId])
  @@index([campaignId])
  @@index([leadId])
  @@index([eventType])
  @@index([createdAt])
  @@map("growth_billing_simulation_events")
}

model PrepaidIncentivePolicy {
