NODE_ENV=development
APP_ENV=development
H2A_SYNTHETIC_TENANT_LIFECYCLE_ENABLED=false
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shipmastr
JWT_SECRET=change_me_long_random_secret_min_32_chars
APP_SECRET_PEPPER=change_me_distinct_hash_pepper_min_32_chars
WEBHOOK_SECRET=change_me_webhook_secret_min_32_chars
# Test-only/provider mapping names. Runtime tenant secrets must resolve through the credential vault; no global fallback is permitted.
SHOPIFY_WEBHOOK_SECRET=replace-with-test-or-runtime-secret
WOOCOMMERCE_WEBHOOK_SECRET=replace-with-test-or-runtime-secret
MAGENTO_WEBHOOK_SECRET=replace-with-test-or-runtime-secret
TRUSTED_PROXY_HOPS=0
SHIPMASTR_AUTOMATION_SMOKE_CALLBACKS_ENABLED=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://shipmastr.com,https://www.shipmastr.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@shipmastr.com
SMTP_PASS=
SMTP_FROM="Shipmastr <noreply@shipmastr.com>"
SMTP_REPLY_TO=no-reply@shipmastr.com
ADMIN_EMAIL=
JOURNAL_EMAIL_PROVIDER=smtp
JOURNAL_EMAIL_LIVE_SEND=false
JOURNAL_AUTOPUBLISH_STORE=postgres
EMAIL_FROM=noreply@shipmastr.com
EMAIL_FROM_NAME=Shipmastr
DOMAIN_EMAIL_FROM_NAME=Shipmastr
DOMAIN_EMAIL_FROM_ADDRESS=noreply@shipmastr.com
NEWSLETTER_SECRET=change_me_newsletter_secret_min_32_chars
JOURNAL_ADMIN_TOKEN=change_me_journal_admin_token_min_32_chars
EMAIL_SPF_VERIFIED=false
EMAIL_DKIM_VERIFIED=false
EMAIL_DMARC_VERIFIED=false
EMAIL_DKIM_SELECTORS=google,default,selector1,selector2,resend
CARRIER_PROVIDER=manual
CARRIER_API_BASE_URL=
CARRIER_API_KEY_SECRET_NAME=
CARRIER_ACCOUNT_ID_SECRET_NAME=
CARRIER_WEBHOOK_SECRET_NAME=
