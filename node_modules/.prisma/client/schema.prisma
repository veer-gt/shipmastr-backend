generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMode {
  PREPAID
  COD
}

enum OrderStatus {
  CREATED
  RISK_SCORED
  VERIFIED
  HELD
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  NDR
  RTO
  CANCELLED
}

enum RiskDecision {
  SHIP
  VERIFY
  HOLD
  BLOCK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WebhookProvider {
  CARRIER
  CHANNEL
  PAYMENT
  INTERNAL
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  orders    Order[]
  auditLogs AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  merchantId   String
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("OWNER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  merchantId      String
  externalOrderId String
  buyerName       String
  buyerPhone      String
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  pincode         String
  orderValue      Int
  codAmount       Int         @default(0)
  paymentMode     PaymentMode
  weightGrams     Int?
  status          OrderStatus @default(CREATED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  riskScores    RiskScore[]
  webhookEvents WebhookEvent[]

  @@unique([merchantId, externalOrderId])
  @@index([merchantId, buyerPhone])
  @@index([merchantId, pincode])
  @@index([status])
}

model RiskScore {
  id                String       @id @default(cuid())
  orderId           String
  score             Int
  level             RiskLevel
  decision          RiskDecision
  addressConfidence Int
  reasons           Json
  modelVersion      String       @default("rules-v1")
  createdAt         DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([level])
  @@index([decision])
}

model WebhookEvent {
  id             String          @id @default(cuid())
  provider       WebhookProvider
  eventType      String
  externalId     String
  orderId        String?
  payload        Json
  signatureValid Boolean         @default(false)
  status         WebhookStatus   @default(RECEIVED)
  error          String?
  receivedAt     DateTime        @default(now())
  processedAt    DateTime?

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([eventType])
  @@index([status])
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  route     String
  response  Json?
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  merchantId String?
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([action])
}
